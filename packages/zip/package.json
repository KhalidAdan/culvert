{
  "name": "@culvert/zip",
  "version": "0.1.1",
  "description": "Streaming ZIP writer and reader. Constant memory. Predictable backpressure. Works in Node and the browser.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KhalidAdan/culvert.git"
  },
  "bugs": {
    "url": "https://github.com/KhalidAdan/culvert/issues"
  },
  "homepage": "#",
  "type": "module",
  "main": "dist/index",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@culvert/stream": "^0.1.1",
    "@culvert/crc32": "^0.1.1"
  },
  "keywords": [
    "zip",
    "archive",
    "streaming",
    "zip64",
    "compression",
    "deflate",
    "cbz"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "author": "Khalid Adan",
  "license": "MIT"
}
