{
  "name": "@culvert/stream",
  "version": "0.1.1",
  "description": "The missing standard library for streaming in JavaScript.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KhalidAdan/culvert.git"
  },
  "bugs": {
    "url": "https://github.com/KhalidAdan/culvert/issues"
  },
  "homepage": "#",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "stream",
    "streaming",
    "async-iterator",
    "pipe",
    "backpressure",
    "pipeline",
    "transform"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "author": "Khalid Adan",
  "license": "MIT"
}
